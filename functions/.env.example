# Firebase Functions runtime environment
# Copy to functions/.env and fill real values before deploy

NODE_ENV=production

# Required for database-backed API routes
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/myblog?retryWrites=true&w=majority

# Required by auth routes
JWT_SECRET=replace-with-64-plus-char-random-string
JWT_EXPIRES_IN=1h
JWT_ISSUER=myblog-api
JWT_AUDIENCE=myblog-client

# Comma-separated list of allowed frontend origins
# Example: https://myblog.web.app,https://myblog.firebaseapp.com
ALLOWED_ORIGINS=https://your-frontend-domain
