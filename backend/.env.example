# ========================================
# MyBlog Application - Environment Configuration
# ========================================
# Copy this file to .env and fill in production values
# NEVER commit .env with real secrets to version control!
# ========================================

# ========== SERVER CONFIGURATION ==========
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# ========== DATABASE - MONGODB ==========
# Production: Use Atlas URI with authentication
# mongodb+srv://username:password@cluster.mongodb.net/myblog?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/myblog?retryWrites=true&w=majority

# MongoDB connection pool settings
MONGODB_POOL_MIN=5
MONGODB_POOL_MAX=20
MONGODB_CONNECTION_TIMEOUT=5000
MONGODB_SOCKET_TIMEOUT=45000

# ========== JWT & SESSION SECURITY ==========
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be 64+ characters in production
JWT_SECRET=generate-with-64-char-random-string-minimum
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used for session signing - MUST be 64+ characters
SESSION_SECRET=generate-with-64-char-random-string-minimum
SESSION_NAME=myblog_session
SESSION_MAX_AGE=3600000
SESSION_ABSOLUTE_MAX_AGE=86400000

# ========== CSRF & COOKIE SECURITY ==========
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be 32+ characters in production
CSRF_SECRET=generate-with-32-char-random-string-minimum

# Cookie Security - Set to true in production with HTTPS
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
COOKIE_HTTP_ONLY=true
COOKIE_DOMAIN=yourdomain.com
COOKIE_PATH=/

# ========== CORS - ALLOWED ORIGINS ==========
# Comma-separated list of allowed origins
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========== RATE LIMITING ==========
# In milliseconds: 15 minutes = 900000
RATE_LIMIT_WINDOW_MS=900000
# General API requests per window
RATE_LIMIT_MAX_REQUESTS=100
# Authentication attempts per window
RATE_LIMIT_AUTH_MAX_REQUESTS=5
# MFA verification attempts per window
RATE_LIMIT_MFA_MAX_REQUESTS=3
# Password reset attempts per hour
RATE_LIMIT_PASSWORD_RESET_MAX_REQUESTS=3

# ========== PROXY CONFIGURATION ==========
# Set to 1 if behind a reverse proxy (e.g., nginx, cloudflare, AWS ELB)
# This affects IP detection for rate limiting and logging
TRUST_PROXY=1

# ========== ENCRYPTION ==========
# Generate encryption key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be 64 hex characters (32 bytes)
ENCRYPTION_KEY=generate-with-64-hex-char-string
ENCRYPTION_ALGORITHM=aes-256-gcm

# ========== ADMIN BOOTSTRAP CREDENTIALS ==========
# Only used for initial admin account creation
# Delete or disable in production after first run
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
# Generate strong password: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_PASSWORD=GenerateStrongPasswordHere123!@#

# ========== EMAIL CONFIGURATION ==========
# Required for email verification and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=MyBlog

# Email verification timeout (24 hours in ms)
EMAIL_VERIFICATION_TIMEOUT=86400000
EMAIL_VERIFICATION_RESEND_COOLDOWN=60000

# ========== SECURITY HEADERS ==========
# Content Security Policy - adjust for your domain
CSP_SCRIPT_SRC=https://yourdomain.com
CSP_STYLE_SRC=https://yourdomain.com
CSP_IMG_SRC=https: data:
CSP_CONNECT_SRC=https://yourdomain.com
CSP_FONT_SRC=https://yourdomain.com
CSP_DEFAULT_SRC=https://yourdomain.com

# HSTS Preload - set to true only after testing
HSTS_PRELOAD=false
HSTS_MAX_AGE=31536000

# ========== LOGGING & MONITORING ==========
# Log sensitive data (set to false in production)
LOG_SENSITIVE_DATA=false
# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=90
# Enable request/response logging
LOG_REQUESTS=true
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ========== SECURITY FEATURES ==========
# Enable/Disable features
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true
ENABLE_CSRF_PROTECTION=true
ENABLE_XSS_PROTECTION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_ACCOUNT_LOCKOUT=true
ENABLE_CAPTCHA=true

# Account lockout settings
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ========== EXTERNAL SERVICES ==========
# Add keys for any external security services
SENTRY_DSN=
DATADOG_API_KEY=
CLOUDFLARE_API_KEY=

# ========== SENSITIVE DATA MASKING ==========
# Enable masking of sensitive data in logs
MASK_PASSWORDS=true
MASK_EMAILS=true
MASK_TOKENS=true
MASK_IP_ADDRESSES=false

# ========== API VERSIONING ==========
API_VERSION=v1
API_VERSION_DEPRECATED=v0
API_DEPRECATION_DATE=2024-06-01

# ========== BACKUP & DISASTER RECOVERY ==========
# MongoDB backup configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_S3_BUCKET=myblog-backups
BACKUP_S3_REGION=us-east-1

# ========== COMPLIANCE ==========
# GDPR data retention (days)
DATA_RETENTION_DAYS=365
# Feature flags
ENABLE_GDPR_EXPORT=true
ENABLE_ACCOUNT_DELETION=true

# ========== DEVELOPMENT/TESTING ONLY ==========
# Set to true to disable certain security features for testing
DISABLE_RATE_LIMITING=false
# Auto-generate test users
GENERATE_TEST_DATA=false
# Allow unverified email in development
SKIP_EMAIL_VERIFICATION=false
